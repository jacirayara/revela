{% doc %}
  @prompt
    Create a product.lookbook template for a luxury sleepwear brand's Lookbook/Gallery collection. This template should display the product images and title only — no price, no variant selectors (size/set type), no add-to-cart button, and no "Sold Out" badge or label. The layout should be clean, editorial, and minimalistic, suitable for showcasing past fabric collections as visual-only gallery items. Keep the product description visible if present.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-lookbook-product-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.vertical_spacing }}px {{ block.settings.horizontal_spacing }}px;
  }

  .ai-lookbook-product__inner-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-lookbook-product__media-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-lookbook-product__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-lookbook-product__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-lookbook-product__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-lookbook-product__content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-lookbook-product__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-lookbook-product__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-lookbook-product__description-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-lookbook-product__description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-lookbook-product-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_spacing | times: 0.7 }}px {{ block.settings.horizontal_spacing | times: 0.7 }}px;
    }

    .ai-lookbook-product__inner-{{ ai_gen_id }} {
      gap: {{ block.settings.content_gap | times: 0.8 }}px;
    }

    .ai-lookbook-product__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-lookbook-product__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-lookbook-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-lookbook-product__inner-{{ ai_gen_id }}">
    <div class="ai-lookbook-product__media-{{ ai_gen_id }}">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 2000 }}"
          alt="{{ product.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ product.featured_image.width }}"
          height="{{ product.featured_image.height }}"
          class="ai-lookbook-product__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-lookbook-product__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-lookbook-product__content-{{ ai_gen_id }}">
      {% if product.title %}
        <h1 class="ai-lookbook-product__title-{{ ai_gen_id }}">
          {{ product.title }}
        </h1>
      {% endif %}

      {% if product.description != blank and block.settings.show_description %}
        <div class="ai-lookbook-product__description-{{ ai_gen_id }}">
          {{ product.description }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lookbook product",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "vertical_spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "horizontal_spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal spacing",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Gap between image and text",
      "default": 30
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "4/5",
          "label": "Portrait (4:5)"
        },
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16/9",
          "label": "Landscape (16:9)"
        }
      ],
      "default": "3/4"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 32
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.5
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color",
      "default": "#38373a"
    },
    {
      "type": "header",
      "content": "Alignment"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Lookbook product"
    }
  ]
}
{% endschema %}
