      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "vertical_spacing",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Vertical spacing",
      "default": 60
    },
    {
      "type": "range",
      "id": "horizontal_spacing",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Horizontal spacing",
      "default": 20
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "max_images",
      "min": 1,
      "max": 12,
      "step": 1,
      "label": "Maximum images",
      "default": 6
    },
    {
      "type": "range",
      "id": "image_gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Image gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Space below gallery",
      "default": 40
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
