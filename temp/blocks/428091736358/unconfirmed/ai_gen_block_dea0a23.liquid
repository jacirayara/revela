{% doc %}
  @prompt
    Create a "Customer Love" page template for a luxury sleepwear brand (Revela Sleepwear) with the following sections:1. Hero/Featured Review Section — Full-width or large card with a single standout quote: "The most comfortable pyjamas I've ever owned. The quality is exceptional and the fit is perfect." Include customer first name, location, optional photo, and star rating (5 stars). Elegant, editorial styling with soft/neutral tones.2. Video Testimonial Section — A section directly below the hero that allows embedding a video (YouTube or Vimeo URL) with a heading like "Hear From Our Customers".3. More Customer Reviews — A grid of review cards/tiles, each with: star rating, review text, customer first name and location, and optional photo. Minimum 3 cards displayed in a responsive grid.4. Call to Action Section — Full-width CTA banner with the text "Ready to experience Revela for yourself?" and a button labelled "Shop Collection" linking to the collections page.The design should feel premium and editorial — clean typography, soft backgrounds (cream/blush tones), generous whitespace. All content should be editable via the Shopify theme editor (using schema settings). Make this a standalone page template called page.customer-love.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 80px 20px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-cta-banner__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .ai-cta-banner__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    font-weight: 400;
    letter-spacing: 0.5px;
    line-height: 1.3;
  }

  .ai-cta-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    border-radius: {{ block.settings.button_radius }}px;
    transition: background-color 0.3s ease, transform 0.2s ease;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .ai-cta-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-cta-banner-{{ ai_gen_id }} {
      padding: 60px 20px;
    }

    .ai-cta-banner__container-{{ ai_gen_id }} {
      gap: 24px;
    }

    .ai-cta-banner__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-cta-banner__button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-cta-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-banner__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-cta-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-cta-banner__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to experience Revela for yourself?"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FAF8F5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#38373a"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#38373a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Button vertical padding",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Button horizontal padding",
      "min": 24,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1200,
      "step": 100,
      "unit": "px",
      "default": 800
    }
  ],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
