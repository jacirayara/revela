{% doc %}
  @prompt
    Create a "Customer Love" page template for a luxury sleepwear brand (Revela Sleepwear) with the following sections:1. Hero/Featured Review Section — Full-width or large card with a single standout quote: "The most comfortable pyjamas I've ever owned. The quality is exceptional and the fit is perfect." Include customer first name, location, optional photo, and star rating (5 stars). Elegant, editorial styling with soft/neutral tones.2. Video Testimonial Section — A section directly below the hero that allows embedding a video (YouTube or Vimeo URL) with a heading like "Hear From Our Customers".3. More Customer Reviews — A grid of review cards/tiles, each with: star rating, review text, customer first name and location, and optional photo. Minimum 3 cards displayed in a responsive grid.4. Call to Action Section — Full-width CTA banner with the text "Ready to experience Revela for yourself?" and a button labelled "Shop Collection" linking to the collections page.The design should feel premium and editorial — clean typography, soft backgrounds (cream/blush tones), generous whitespace. All content should be editable via the Shopify theme editor (using schema settings). Make this a standalone page template called page.customer-love.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-testimonial-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-testimonial__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-video-testimonial__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0 0 40px;
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .ai-video-testimonial__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: #000000;
  }

  .ai-video-testimonial__video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-testimonial__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
    gap: 16px;
  }

  .ai-video-testimonial__placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-testimonial__placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-video-testimonial-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-video-testimonial__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
      margin-bottom: 24px;
    }
  }
{% endstyle %}

<div class="ai-video-testimonial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-testimonial__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-video-testimonial__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-video-testimonial__video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video_url != blank %}
        {% assign video_url = block.settings.video_url %}
        {% if video_url contains 'youtube.com' or video_url contains 'youtu.be' %}
          {% if video_url contains 'youtu.be/' %}
            {% assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first %}
          {% elsif video_url contains 'watch?v=' %}
            {% assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first %}
          {% elsif video_url contains 'embed/' %}
            {% assign video_id = video_url | split: 'embed/' | last | split: '?' | first %}
          {% endif %}
          <iframe
            src="https://www.youtube.com/embed/{{ video_id }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        {% elsif video_url contains 'vimeo.com' %}
          {% assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first %}
          <iframe
            src="https://player.vimeo.com/video/{{ video_id }}"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        {% endif %}
      {% else %}
        <div class="ai-video-testimonial__placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          <p class="ai-video-testimonial__placeholder-text-{{ ai_gen_id }}">Add a YouTube or Vimeo URL</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video testimonial",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hear From Our Customers"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "paragraph",
      "content": "Supports YouTube and Vimeo URLs. Paste the full URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID or https://vimeo.com/VIDEO_ID)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#38373a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Video border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1200,
      "step": 100,
      "unit": "px",
      "default": 900
    }
  ],
  "presets": [
    {
      "name": "Video testimonial"
    }
  ]
}
{% endschema %}
