{% doc %}
  @prompt
    Create a "Customer Love" page template for a luxury sleepwear brand (Revela Sleepwear) with the following sections:1. Hero/Featured Review Section — Full-width or large card with a single standout quote: "The most comfortable pyjamas I've ever owned. The quality is exceptional and the fit is perfect." Include customer first name, location, optional photo, and star rating (5 stars). Elegant, editorial styling with soft/neutral tones.2. Video Testimonial Section — A section directly below the hero that allows embedding a video (YouTube or Vimeo URL) with a heading like "Hear From Our Customers".3. More Customer Reviews — A grid of review cards/tiles, each with: star rating, review text, customer first name and location, and optional photo. Minimum 3 cards displayed in a responsive grid.4. Call to Action Section — Full-width CTA banner with the text "Ready to experience Revela for yourself?" and a button labelled "Shop Collection" linking to the collections page.The design should feel premium and editorial — clean typography, soft backgrounds (cream/blush tones), generous whitespace. All content should be editable via the Shopify theme editor (using schema settings). Make this a standalone page template called page.customer-love.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-review-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-review-grid__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-review-grid__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0 0 48px;
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .ai-review-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: 32px;
    border-radius: {{ block.settings.card_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-review-card__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-review-card__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-card__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
    flex-grow: 1;
  }

  .ai-review-card__customer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .ai-review-card__photo-{{ ai_gen_id }} {
    width: {{ block.settings.photo_size }}px;
    height: {{ block.settings.photo_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-review-card__photo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-review-card__photo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-review-card__photo-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-review-card__info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-review-card__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
    margin: 0;
  }

  .ai-review-card__location-{{ ai_gen_id }} {
    font-size: {{ block.settings.location_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-review-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-review-grid-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-review-grid__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
      margin-bottom: 32px;
    }

    .ai-review-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-review-card-{{ ai_gen_id }} {
      padding: 24px;
    }
  }
{% endstyle %}

<div class="ai-review-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-review-grid__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-review-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-review-grid__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign review_text_key = 'review_' | append: i | append: '_text'
          assign customer_name_key = 'review_' | append: i | append: '_name'
          assign customer_location_key = 'review_' | append: i | append: '_location'
          assign customer_photo_key = 'review_' | append: i | append: '_photo'
          assign show_review_key = 'show_review_' | append: i

          assign review_text = block.settings[review_text_key]
          assign customer_name = block.settings[customer_name_key]
          assign customer_location = block.settings[customer_location_key]
          assign customer_photo = block.settings[customer_photo_key]
          assign show_review = block.settings[show_review_key]
        %}

        {% if show_review %}
          <div class="ai-review-card-{{ ai_gen_id }}">
            <div class="ai-review-card__stars-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <svg class="ai-review-card__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>

            {% if review_text != blank %}
              <p class="ai-review-card__text-{{ ai_gen_id }}">{{ review_text }}</p>
            {% endif %}

            <div class="ai-review-card__customer-{{ ai_gen_id }}">
              {% if block.settings.show_photos %}
                <div class="ai-review-card__photo-{{ ai_gen_id }}">
                  {% if customer_photo %}
                    <img
                      src="{{ customer_photo | image_url: width: 100 }}"
                      alt="{{ customer_name | escape }}"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  {% else %}
                    <div class="ai-review-card__photo-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              <div class="ai-review-card__info-{{ ai_gen_id }}">
                {% if customer_name != blank %}
                  <p class="ai-review-card__name-{{ ai_gen_id }}">{{ customer_name }}</p>
                {% endif %}
                {% if customer_location != blank %}
                  <p class="ai-review-card__location-{{ ai_gen_id }}">{{ customer_location }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

