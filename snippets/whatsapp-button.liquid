{%- comment -%}
  Floating WhatsApp chat button.
  Number is hardcoded; update here if it changes.
{%- endcomment -%}
{%- assign whatsapp_number = '27625371869' -%}
{%- assign whatsapp_message = 'Hi Revela, I have a question about your sleepwear.' -%}

<style>
  .revela-whatsapp {
    position: fixed;
    right: 2.4rem;
    bottom: 6rem;
    z-index: 99;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5.6rem;
    height: 5.6rem;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }
  .revela-whatsapp:hover,
  .revela-whatsapp:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.22);
    color: #fff;
  }
  .revela-whatsapp svg {
    width: 3rem;
    height: 3rem;
    fill: currentColor;
  }
  .revela-whatsapp__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media screen and (max-width: 749px) {
    .revela-whatsapp {
      right: 1.6rem;
      bottom: 5rem;
      width: 5rem;
      height: 5rem;
    }
    .revela-whatsapp svg {
      width: 2.6rem;
      height: 2.6rem;
    }
  }
</style>

<a
  class="revela-whatsapp"
  href="https://wa.me/{{ whatsapp_number }}?text={{ whatsapp_message | url_encode }}"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat with Revela on WhatsApp"
>
  <span class="revela-whatsapp__label">Chat on WhatsApp</span>
  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M16.001 3.2C8.93 3.2 3.2 8.93 3.2 16c0 2.262.59 4.467 1.714 6.41L3.2 28.8l6.55-1.708A12.787 12.787 0 0 0 16 28.8C23.07 28.8 28.8 23.07 28.8 16S23.07 3.2 16.001 3.2Zm0 23.36a10.55 10.55 0 0 1-5.379-1.471l-.385-.229-3.886 1.014 1.037-3.79-.251-.4A10.547 10.547 0 0 1 5.44 16c0-5.83 4.733-10.56 10.561-10.56 5.83 0 10.56 4.731 10.56 10.56 0 5.83-4.731 10.56-10.56 10.56Zm5.795-7.91c-.317-.16-1.879-.928-2.17-1.034-.292-.107-.504-.16-.717.16-.213.317-.823 1.034-1.009 1.247-.187.214-.372.24-.69.08-.317-.16-1.339-.493-2.55-1.572-.943-.842-1.58-1.881-1.764-2.198-.187-.317-.02-.488.14-.647.143-.143.317-.372.476-.559.16-.187.213-.317.32-.531.107-.214.054-.4-.027-.56-.08-.16-.717-1.728-.983-2.367-.259-.621-.521-.537-.717-.547l-.61-.011a1.17 1.17 0 0 0-.85.4c-.293.317-1.116 1.09-1.116 2.66s1.142 3.082 1.301 3.296c.16.213 2.249 3.43 5.45 4.81.762.328 1.355.524 1.819.671.764.243 1.46.209 2.01.127.614-.092 1.879-.768 2.144-1.512.266-.744.266-1.382.186-1.512-.08-.133-.293-.213-.61-.373Z"/>
  </svg>
</a>
